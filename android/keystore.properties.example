# Copy this file to android/keystore.properties (gitignored, never commit it)
# and fill in the real values once you're ready to build a signed release.
#
# The actual upload key lives at ../keystore/global-recall-upload.jks
# (relative to this file: android/keystore.properties -> keystore/...).
# Its password is in ../keystore/credentials.txt — back that up somewhere
# outside git before you lose access to this machine.

storeFile=../keystore/global-recall-upload.jks
storePassword=REPLACE_WITH_KEYSTORE_PASSWORD
keyAlias=global-recall
keyPassword=REPLACE_WITH_KEYSTORE_PASSWORD
